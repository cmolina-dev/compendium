---
interface Props {
  title: string;
  slug: string;
  category: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { title, slug, category, description, date, tags = [] } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<a href={`/topics/${slug}`} class="topic-card retro-card">
  <div class="retro-card__header">
    <h3 class="retro-card__title">{title}</h3>
  </div>
  <div class="retro-card__body">
    {description && <p class="topic-card__description">{description}</p>}
    <div class="topic-card__meta">
      <span class="topic-card__date">&#128197; {formattedDate}</span>
      <span class="retro-badge--blue retro-badge">{category}</span>
    </div>
  </div>
  {tags.length > 0 && (
    <div class="retro-card__footer">
      {tags.slice(0, 3).map((tag) => (
        <span class="retro-badge--purple retro-badge">{tag}</span>
      ))}
      {tags.length > 3 && (
        <span class="topic-card__more">+{tags.length - 3}</span>
      )}
    </div>
  )}
</a>

<style>
  .topic-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .topic-card__description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-md) 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .topic-card__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .topic-card__date {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .topic-card__more {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .retro-card__body {
    flex: 1;
  }
</style>
