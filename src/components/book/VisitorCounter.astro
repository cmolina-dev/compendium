---
/**
 * Contador de visitantes estilo biblioteca/odómetro
 * Puramente decorativo con número fijo o animado
 */
interface Props {
  count?: number;
}

const { count = 1337 } = Astro.props;
const digits = count.toString().padStart(6, "0").split("");
---

<div class="visitor-counter" aria-label={`${count} visitantes`}>
  <span class="visitor-counter__label">N° DE VISITANTES</span>
  <div class="visitor-counter__display">
    {
      digits.map((digit, i) => (
        <span
          class="visitor-counter__digit"
          style={`animation-delay: ${i * 0.1}s`}
        >
          {digit}
        </span>
      ))
    }
  </div>
</div>

<style>
  .visitor-counter {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .visitor-counter__label {
    font-family: var(--font-code);
    font-size: 7px;
    letter-spacing: 2px;
    color: var(--ink-faded);
  }

  .visitor-counter__display {
    display: flex;
    background: #0a0a0a;
    border: 3px solid #2a2a2a;
    border-radius: 4px;
    padding: var(--space-1);
    box-shadow:
      inset 0 2px 4px rgba(0, 0, 0, 0.8),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .visitor-counter__digit {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 26px;
    font-family: var(--font-code);
    font-size: var(--text-base);
    font-weight: bold;
    color: #33ff33;
    text-shadow: 0 0 5px rgba(51, 255, 51, 0.5);
    background: linear-gradient(180deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%);
    border-right: 1px solid #1a1a1a;

    /* Efecto CRT sutil */
    animation: digit-flicker 4s ease-in-out infinite;
  }

  .visitor-counter__digit:last-child {
    border-right: none;
  }

  @keyframes digit-flicker {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.95;
    }
    52% {
      opacity: 1;
    }
    54% {
      opacity: 0.97;
    }
  }

  /* Líneas de escaneo CRT */
  /* .visitor-counter__display::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.1) 2px,
      rgba(0, 0, 0, 0.1) 4px
    );
    pointer-events: none;
    border-radius: 2px;
  } */

  @media (prefers-reduced-motion: reduce) {
    .visitor-counter__digit {
      animation: none;
    }
  }
</style>
