---
/**
 * Ex-Libris (marca de propiedad del libro)
 * Aparece en la página izquierda como sello de propiedad
 */
interface Props {
  owner?: string;
}

const { owner = 'Compendium' } = Astro.props;
---

<div class="ex-libris" aria-label={`Ex Libris de ${owner}`}>
  <div class="ex-libris__frame">
    <svg class="ex-libris__icon" viewBox="0 0 50 50" aria-hidden="true">
      <!-- Libro abierto estilizado -->
      <path 
        d="M25 10 L10 15 L10 40 L25 35 L40 40 L40 15 Z" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="1.5"
      />
      <line x1="25" y1="10" x2="25" y2="35" stroke="currentColor" stroke-width="1"/>
      <!-- Páginas -->
      <path d="M12 18 L23 16 M12 23 L23 21 M12 28 L23 26" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
      <path d="M27 16 L38 18 M27 21 L38 23 M27 26 L38 28" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
      <!-- Estrella superior -->
      <polygon points="25,5 26,8 29,8 27,10 28,13 25,11 22,13 23,10 21,8 24,8" fill="currentColor" opacity="0.7"/>
    </svg>
    <span class="ex-libris__label">EX LIBRIS</span>
    <span class="ex-libris__owner">{owner}</span>
  </div>
  <div class="ex-libris__border" aria-hidden="true">
    <svg viewBox="0 0 100 120">
      <rect x="2" y="2" width="96" height="116" fill="none" stroke="currentColor" stroke-width="1"/>
      <rect x="6" y="6" width="88" height="108" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
      <!-- Ornamentos de esquina -->
      <circle cx="10" cy="10" r="2" fill="currentColor" opacity="0.3"/>
      <circle cx="90" cy="10" r="2" fill="currentColor" opacity="0.3"/>
      <circle cx="10" cy="110" r="2" fill="currentColor" opacity="0.3"/>
      <circle cx="90" cy="110" r="2" fill="currentColor" opacity="0.3"/>
    </svg>
  </div>
</div>

<style>
  .ex-libris {
    position: relative;
    width: 90px;
    text-align: center;
    opacity: 0.6;
    transition: opacity var(--transition-base);
  }

  .ex-libris:hover {
    opacity: 0.8;
  }

  .ex-libris__frame {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-3) var(--space-2);
    color: var(--ink-faded);
  }

  .ex-libris__icon {
    width: 45px;
    height: 45px;
    margin-bottom: var(--space-2);
  }

  .ex-libris__label {
    font-family: var(--font-heading);
    font-size: 7px;
    letter-spacing: 3px;
    margin-bottom: var(--space-1);
  }

  .ex-libris__owner {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-style: italic;
  }

  .ex-libris__border {
    position: absolute;
    inset: 0;
    color: var(--ink-faded);
    pointer-events: none;
  }

  .ex-libris__border svg {
    width: 100%;
    height: 100%;
  }
</style>
