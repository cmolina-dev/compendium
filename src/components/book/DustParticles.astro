---
/**
 * Partículas de polvo flotantes
 * Efecto atmosférico sutil al cargar la página
 */
interface Props {
  count?: number;
}

const { count = 15 } = Astro.props;
const particles = Array.from({ length: count }, (_, i) => ({
  id: i,
  left: Math.random() * 100,
  delay: Math.random() * 10,
  duration: 10 + Math.random() * 10,
  size: 1 + Math.random() * 2
}));
---

<div class="dust-particles" aria-hidden="true">
  {particles.map(p => (
    <span 
      class="dust-particle"
      style={`
        left: ${p.left}%;
        animation-delay: ${p.delay}s;
        animation-duration: ${p.duration}s;
        width: ${p.size}px;
        height: ${p.size}px;
      `}
    />
  ))}
</div>

<style>
  .dust-particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1000;
    overflow: hidden;
  }

  .dust-particle {
    position: absolute;
    bottom: -10px;
    background: var(--dust-particle);
    border-radius: 50%;
    opacity: 0;
    animation: float-dust linear infinite;
  }

  @keyframes float-dust {
    0% {
      transform: translateY(0) translateX(0) rotate(0deg);
      opacity: 0;
    }
    5% {
      opacity: 0.6;
    }
    50% {
      transform: translateY(-50vh) translateX(20px) rotate(180deg);
      opacity: 0.4;
    }
    95% {
      opacity: 0.2;
    }
    100% {
      transform: translateY(-100vh) translateX(-10px) rotate(360deg);
      opacity: 0;
    }
  }

  /* Desactivar si el usuario prefiere menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .dust-particles {
      display: none;
    }
  }
</style>
